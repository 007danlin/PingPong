<Window x:Class="PingPongModalWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PingPongModalWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        ResizeMode="NoResize">
    <Grid Margin="40,25,40,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="PingPong"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Режим:" Width="150" FontSize="16" VerticalAlignment="Center"/>
            <ComboBox x:Name="playersComboBox" Width="170" Height="28" SelectedIndex="0">
                <ComboBoxItem Content="1 игрок"/>
                <ComboBoxItem Content="2 игрока"/>
            </ComboBox>

            <TextBlock Text="Очки:" Width="90" FontSize="16" Margin="35,0,0,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="pointsComboBox" Width="100" Height="28" SelectedIndex="0">
                <ComboBoxItem Content="11"/>
                <ComboBoxItem Content="21"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Ракетка 1:" Width="150" FontSize="16" VerticalAlignment="Center"/>
            <ComboBox x:Name="racket1ComboBox" Width="170" Height="28" SelectedIndex="0">
                <ComboBoxItem Content="Деревянная"/>
                <ComboBoxItem Content="Кожаная"/>
                <ComboBoxItem Content="Полиуретановая"/>
            </ComboBox>

            <TextBlock Text="Ракетка 2:" Width="90" FontSize="16" Margin="35,0,0,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="racket2ComboBox" Width="170" Height="28" SelectedIndex="0">
                <ComboBoxItem Content="Деревянная"/>
                <ComboBoxItem Content="Кожаная"/>
                <ComboBoxItem Content="Полиуретановая"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Мяч:" Width="150" FontSize="16" VerticalAlignment="Center"/>
            <ComboBox x:Name="BallComboBox" Width="170" Height="28" SelectedIndex="0">
                <ComboBoxItem Content="Стандартный"/>
                <ComboBoxItem Content="Тяжелый"/>
                <ComboBoxItem Content="Быстрый"/>
            </ComboBox>

            <TextBlock Text="Формат:" Width="90" FontSize="16" Margin="35,0,0,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="SaveFormatComboBox" Width="100" Height="28" SelectedIndex="0" SelectionChanged="FormatChanged">
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="XML"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="Папка:" Width="150" FontSize="16" VerticalAlignment="Center"/>
            <TextBox x:Name="FolderPathBox" Width="390" Height="28" IsReadOnly="True"/>
            <Button x:Name="ChooseFolderButton" Content="Обзор" Width="90" Height="28" Margin="10,0,0,0" Click="ChooseFolderButton_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="NewGameButton" Content="Новая игра" Width="160" Height="40" Margin="10" Click="NewGameButton_Click"/>
            <Button x:Name="ContinueGameButton" Content="Продолжить игру" Width="160" Height="40" Margin="10" Click="ContinueGameButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
