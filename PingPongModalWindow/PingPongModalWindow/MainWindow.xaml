<Window x:Class="PingPongModalWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PingPongModalWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Ping Pong" 
                   FontWeight="Bold" 
                   FontSize="28" 
                   VerticalAlignment="Center" 
                   HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Игроки + Цвет ракеток -->
        <StackPanel Grid.Row="1" 
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,0,0,10">

            <TextBlock Text="Количество игроков:" 
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="0,0,8,0"/>

            <ComboBox Width="180" 
                  SelectedIndex="0"
                  VerticalAlignment="Center">
                <ComboBoxItem Content="1 игрок (игра с ботом)"/>
                <ComboBoxItem Content="2 игрока"/>
            </ComboBox>

            <TextBlock Text="Цвет ракеток:" 
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="20,0,8,0"/>

            <ComboBox Width="130" 
                  SelectedIndex="0"
                  VerticalAlignment="Center">
                <ComboBoxItem Content="Красный"/>
                <ComboBoxItem Content="Черный"/>
                <ComboBoxItem Content="Зелёный"/>
            </ComboBox>
        </StackPanel>

        <!-- Скорость мяча -->
        <StackPanel Grid.Row="2" 
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,0,0,10">

            <TextBlock Text="Скорость мяча:" 
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="0,0,8,0"/>

            <ComboBox Width="180" 
                  SelectedIndex="0"
                  VerticalAlignment="Center">
                <ComboBoxItem Content="Низкая"/>
                <ComboBoxItem Content="Средняя"/>
                <ComboBoxItem Content="Высокая"/>
            </ComboBox>
        </StackPanel>

        <!-- Папка сохранения -->
        <StackPanel Grid.Row="3" 
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,0,0,15">

            <TextBlock Text="Папка сохранения прогресса:" 
                   VerticalAlignment="Center"
                   FontSize="16"
                   Margin="0,0,8,0"/>

            <TextBox x:Name="FolderPathBox"
                 Width="230"
                 VerticalAlignment="Center"
                 IsReadOnly="True"
                 Margin="0,0,6,0"/>

            <Button Content="Обзор..."
                VerticalAlignment="Center"
                Width="70"/>
        </StackPanel>

        <!-- Кнопка Начать игру -->
        <StackPanel Grid.Row="4" 
                HorizontalAlignment="Center"
                Margin="0,5,0,10">

            <Button Content="Начать игру"
                Width="200"
                Height="50"
                FontSize="25"
                FontWeight="Bold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2E7D32"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#1B5E20"/>
                        <Setter Property="BorderThickness" Value="2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#388E3C"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#1B5E20"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

    </Grid>
</Window>
