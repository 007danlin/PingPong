<Window x:Class="PingPongModalWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PingPongModalWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="320" Width="600"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PingPong" FontSize="22" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,15" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Режим:" Width="130" VerticalAlignment="Center"/>
            <ComboBox x:Name="playersComboBox" Width="140" SelectedIndex="0">
                <ComboBoxItem Content="1 игрок"/>
                <ComboBoxItem Content="2 игрока"/>
            </ComboBox>

            <TextBlock Text="Очки:" Width="80" Margin="20,0,0,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="pointsComboBox" Width="80" SelectedIndex="0">
                <ComboBoxItem Content="11"/>
                <ComboBoxItem Content="21"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Ракетка 1:" Width="130" VerticalAlignment="Center"/>
            <ComboBox x:Name="racket1ComboBox" Width="140" SelectedIndex="0">
                <ComboBoxItem Content="Деревянная"/>
                <ComboBoxItem Content="Кожаная"/>
                <ComboBoxItem Content="Полиуретановая"/>
            </ComboBox>

            <TextBlock Text="Ракетка 2:" Width="80" Margin="20,0,0,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="racket2ComboBox" Width="140" SelectedIndex="0">
                <ComboBoxItem Content="Деревянная"/>
                <ComboBoxItem Content="Кожаная"/>
                <ComboBoxItem Content="Полиуретановая"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Мяч:" Width="130" VerticalAlignment="Center"/>
            <ComboBox x:Name="BallComboBox" Width="140" SelectedIndex="0">
                <ComboBoxItem Content="Стандартный"/>
                <ComboBoxItem Content="Тяжелый"/>
            </ComboBox>

            <TextBlock Text="Формат:" Width="80" Margin="20,0,0,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="SaveFormatComboBox" Width="80" SelectedIndex="0">
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="XML"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Папка:" Width="130" VerticalAlignment="Center"/>
            <TextBox x:Name="FolderPathBox" Width="300" IsReadOnly="True"/>
            <Button x:Name="ChooseFolderButton" Content="Обзор" Width="80" Margin="10,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="NewGameButton" Content="Новая игра" Width="140" Height="35" Margin="5"/>
            <Button x:Name="ContinueGameButton" Content="Продолжить игру" Width="140" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
